# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Database
# DB_TYPE=sqlite (default, zero-setup) | DB_TYPE=postgres (prod)
# When sqlite: DB_PATH controls the file location (default: ./data/article-parser.sqlite)
# When postgres: standard POSTGRES_* env vars are read
# ─────────────────────────────────────────────────────────────
DB_TYPE=sqlite
DB_PATH=./data/article-parser.sqlite

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=article_parser

# ─────────────────────────────────────────────────────────────
# OpenAI
# Two-tier model strategy: primary (nuanced AI second-opinion) +
# mini (batched borderline classification, cheap).
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_MODEL_MINI=gpt-5-mini

# Override the model used by the article-validity AI second-opinion
# (defaults to OPENAI_MODEL).
ARTICLE_VALIDITY_MODEL=

# ─────────────────────────────────────────────────────────────
# Google Docs ingestion (optional — only needed for non-public docs)
# Path to a service-account JSON key with Docs API read scope.
# When unset, the pipeline uses the public ?format=html export endpoint.
# ─────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=

# ─────────────────────────────────────────────────────────────
# Publishers — flip MOCK_UPLOAD to false to point at real APIs
# ─────────────────────────────────────────────────────────────
MOCK_UPLOAD=true

WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

SHOPIFY_STORE_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# Quality-gate thresholds (overridable at runtime via AppConfig API)
# Mirrors Sourcerer-Be's VALIDITY_ACCEPT_THRESHOLD pattern.
# ─────────────────────────────────────────────────────────────
QUALITY_ACCEPT_THRESHOLD=3
QUALITY_REJECT_THRESHOLD=-6

QUALITY_MIN_IMAGES=2
QUALITY_MAX_IMAGES=8
QUALITY_MIN_PRODUCT_LINKS=2
QUALITY_MAX_PRODUCT_LINKS=10

# Product link detection — comma-separated host patterns and
# path patterns. Both apply ANDed: host matches AND path matches.
QUALITY_PRODUCT_HOST_PATTERNS=
QUALITY_PRODUCT_PATH_PATTERNS=/products/,/collections/,/product/,/shop/

# ─────────────────────────────────────────────────────────────
# Logging / decision-log artifacts
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=log
LOG_DIR=./logs
ARTIFACTS_ENABLED=true
